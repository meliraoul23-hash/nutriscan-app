{
  "expo": {
    "name": "NutriScan",
    "slug": "nutriscan",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "nutriscan",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-image.png",
      "resizeMode": "contain",
      "backgroundColor": "#4CAF50"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.nutriscanfr.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Scannez les codes-barres pour analyser la nutrition",
        "NSMicrophoneUsageDescription": "Commandes vocales en mode cuisine",
        "NSSpeechRecognitionUsageDescription": "Reconnaissance vocale pour naviguer les recettes",
        "NSPhotoLibraryUsageDescription": "Sauvegarder vos recettes favorites",
        "ITSAppUsesNonExemptEncryption": false
      },
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#4CAF50"
      },
      "package": "com.nutriscanfr.app",
      "versionCode": 2,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.INTERNET",
        "android.permission.VIBRATE"
      ],
      "blockedPermissions": [
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "NutriScan utilise la camera pour scanner les codes-barres alimentaires."
        }
      ],
      "expo-web-browser",
      "expo-video",
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "NutriScan utilise le micro pour les commandes vocales en mode cuisine."
        }
      ],
      "expo-screen-orientation"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "f48109fa-01f6-4642-8f7e-3bfc0835dbbb"
      }
    },
    "owner": "fouken",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/f48109fa-01f6-4642-8f7e-3bfc0835dbbb"
    }
  }
}
